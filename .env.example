PORT=3847
AUTOPSY_DB_PATH=./data/whybot.db

# ── Bitget API (optional for live agent — public market data works without keys) ──
# Get keys: bitget.com → Avatar → API Management → Create API Key
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Paper trading — only if you have API keys and set readOnly=false in code (not for default demo)
BITGET_PAPER_TRADING=false

# Live agent — comma-separated pairs (default: 10 top coins on Bitget)
AGENT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,ARBUSDT
AGENT_WATCH_MS=60000
DASHBOARD_POLL_MS=5000
AGENT_ID=live-regime-router
AGENT_NAME=Live Regime Router

# Vercel (set in Vercel dashboard — uses /tmp for DB, data resets on cold start)
# VERCEL=1
# AGENT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
