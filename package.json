{
  "name": "whybot",
  "version": "1.0.0",
  "description": "WhyBot — post-trade explainability for AI trading agents (Bitget AI Hackathon S1)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "tsx watch src/server/index.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:ci": "npm run build && npm test",
    "demo": "tsx src/demo/run-demo.ts",
    "agent": "tsx src/agent/run-live.ts",
    "agent:clear": "tsx src/agent/run-live.ts --clear",
    "agent:all": "tsx src/agent/run-live.ts",
    "agent:watch": "tsx src/agent/run-live.ts --watch",
    "postinstall": "npm rebuild better-sqlite3",
    "seed": "tsx src/demo/run-demo.ts --seed-only"
  },
  "keywords": [
    "bitget",
    "trading-agent",
    "explainability",
    "mcp",
    "hackathon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshThunder/whybot.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.3.5",
    "better-sqlite3": "^11.7.0",
    "bitget-client": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
